rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for Leaderboard
    function isValidLeaderboardEntry(data) {
      return data.userId == request.auth.uid &&
             data.username is string && data.username.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.devicesSmashed is number && data.devicesSmashed >= 0 &&
             data.updatedAt == request.time;
    }

    // Validation for UserProfile
    function isValidUserProfile(data) {
      return data.userId == request.auth.uid &&
             data.username is string && data.username.size() <= 50 &&
             data.totalScore is number && data.totalScore >= 0 &&
             data.currentLevel is number && data.currentLevel >= 1 &&
             data.unlockedHammers is list && data.unlockedHammers.size() <= 10 &&
             data.equiptHammer is string &&
             data.updatedAt == request.time;
    }

    match /leaderboard/{userId} {
      allow read: if true; // Public leaderboard
      allow create: if isOwner(userId) && isValidLeaderboardEntry(request.resource.data);
      allow update: if isOwner(userId) && isValidLeaderboardEntry(request.resource.data) &&
                    request.resource.data.score >= resource.data.score; // Only allow increasing score
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
    }
  }
}
